import java.util.*;

class Main{
    public static void main(String[]args){
        Scanner scn=new Scanner(System.in);
        int n=scn.nextInt();
        int sum=0;
        
       while(n>0){
           int ld=n%10;
           sum=sum+ld;
           n=n/10;
       }
        System.out.println(sum+"");
    }
}
