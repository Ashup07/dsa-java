import java.util.*;
class Main{
    public static void main(String[]args){
        Scanner scn=new Scanner(System.in);
        int n=scn.nextInt();
        int rev=0;
        int dupli=n;
        while(n>0){
            int ld=n%10;
            rev=rev*10+ld;
            n=n/10;
        }
        if(dupli==rev){
            System.out.println("True");
        }
        else{
            System.out.println("False");
        }
    }
}
