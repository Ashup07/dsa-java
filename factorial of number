    import java.util.*;
    
    class Main{
        public static void main(String[]args){
            Scanner scn=new Scanner(System.in);
            int n=scn.nextInt();
            int original=n;
            int fact=1;
            while(n>0){
                fact=fact*n;
                n--;
            }
            System.out.println("The Factorial of "+original+" is "+fact);
            
        }
    }
